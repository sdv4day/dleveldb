	"name": "dleveldb",
	"sourcePaths": [
		"source"
	],
	"description": "A LevelDB-compatible key-value storage engine written in D",
	"dependencies": {
		"deimos-snappy": "*",
		"cachetools": "~>1.0.1",
		"deimos-zstd": "*",
		"silly": "~>1.1.1"
	},
	"targetType": "library",
	"buildTypes": {
		"debug": {
			"buildOptions": [
				"debugMode",
				"debugInfo"
			]
		},
		"debug-profile": {
			"buildOptions": [
				"debugMode",
				"debugInfo",
				"profile"
			]
		}
	},
	"configurations": [
		{
			"excludedSourceFiles": [
				"source/app.d",
				"source/dual_test_app.d",
				"source/dleveldb/dual_db_test.d"
			],
			"targetType": "library",
			"name": "library"
		},
		{
			"excludedSourceFiles": [
				"source/app.d",
				"source/dual_test_app.d",
				"source/dleveldb/dual_db_test.d"
			],
			"targetType": "library",
			"name": "unittest"
		},
		{
			"excludedSourceFiles": [
				"source/dual_test_app.d",
				"source/dleveldb/dual_db_test.d"
			],
			"mainSourceFile": "source/app.d",
			"targetType": "executable",
			"name": "benchmark"
		},
		{
			"excludedSourceFiles": [
				"source/app.d"
			],
			"mainSourceFile": "source/dual_test_app.d",
			"targetType": "executable",
			"name": "dual_test"
		}
	]
}